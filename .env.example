# App
APP_ENV=production
APP_NAME=Douyin Media Depot
APP_SECRET_KEY=change-this-random-secret
ADMIN_PASSWORD=change-this-password

# Server
HOST=0.0.0.0
PORT=8080
HOST_PORT=3088
PUBLIC_BASE_URL=http://127.0.0.1:3088

# Storage
DATA_DIR=/app/data
DOWNLOAD_DIR=/app/downloads
TEMP_DIR=/app/tmp

# Database
DATABASE_URL=sqlite:////app/data/app.db

# Download
MAX_CONCURRENT_DOWNLOADS=2
REQUEST_TIMEOUT_SECONDS=30
DOWNLOAD_RETRY_LIMIT=3

# Media
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
AUDIO_EXTRACT_MODE=copy

# Optional WebDAV
WEBDAV_ENABLED=false
WEBDAV_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
WEBDAV_REMOTE_DIR=/douyin-media
